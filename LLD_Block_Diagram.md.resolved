## 5. Database Entity Relationship (ERD)

```mermaid
erDiagram
    User {
        string id PK
        string public_id
        string first_name
        string last_name
        string email
        string hashed_password
        string role
        string phone_number
        bool   is_active
        bool   is_verified
        datetime created_at
    }

    Investor {
        string  id PK
        string  user_id FK
        date    date_of_birth
        string  pan_number
        decimal annual_income
        decimal duration
        int     q1
        int     q2
        int     q3
        int     q4
        float   stated_risk_score
        float   risk_capacity_score
        float   revealed_risk_score
        float   final_risk_score
        string  risk_profile
        string  user_type
    }

    Advisor {
        string id PK
        string user_id FK
        string arn_number
    }

    MutualFund {
        int    scheme_code PK
        string scheme_name
        string fund_house
        string scheme_type
        string scheme_category
        string fund_category
        decimal expense_ratio
        decimal min_investment
        bool   is_active
        datetime last_synced_at
    }

    FundMetrics {
        int    scheme_code FK
        float  fqs
        float  frs
        float  cagr
        float  cagr_1y
        float  cagr_3y
        float  cagr_5y
        float  volatility
        float  sortino
        float  beta
        float  alpha
        float  max_drawdown
        float  latest_nav
        date   metrics_start_date
        date   metrics_end_date
    }

    NAVHistory {
        int  id PK
        int  scheme_code FK
        date data__date
        float data__nav
    }

    PortfolioTransaction {
        int    id PK
        string investor_id FK
        int    scheme_code FK
        decimal amount
        float  nav_at_purchase
        float  units
        string status
        string ai_explanation
        float  investment_duration
        string approved_by_advisor_id
        string rejection_reason
        datetime transaction_date
        datetime approval_date
    }

    OTP {
        string  id PK
        string  email
        string  otp_code
        bool    used
        datetime expires_at
        datetime created_at
    }

    TokenBlacklist {
        int    id PK
        string token
        datetime created_at
    }

    User ||--o| Investor : "has"
    User ||--o| Advisor  : "has"
    Investor ||--o{ PortfolioTransaction : "places"
    MutualFund ||--o| FundMetrics : "has"
    MutualFund ||--o{ NAVHistory : "has"
    MutualFund ||--o{ PortfolioTransaction : "in"
```

