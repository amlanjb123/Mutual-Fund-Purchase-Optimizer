            M_FM["fund_metrics.py\nFundMetrics"]
            M_PORT["portfolio.py\nPortfolioTransaction"]
            M_OTP["otp.py\nOTP"]
            M_TK["token_blacklist.py\nTokenBlacklist"]
            M_CLIENT["client.py"]
            M_PW["password_reset.py"]
            M_TER["fund_ter_history.py"]
        end

        subgraph Schemas["Pydantic Schemas  (schemas/)"]
            S_AUTH["auth.py"]
            S_INV["investor.py"]
            S_ADV["advisor.py"]
            S_ADM["admin.py"]
            S_FUND["funds.py"]
            S_REC["recommendations.py"]
            S_OTP["otp.py"]
            S_PW["password_reset.py"]
        end
    end

    MAIN --> Routers
    Routers --> Core
    Routers --> Services
    Routers --> Models
    Routers --> Schemas
    Core --> DB
    Models --> DB
```

