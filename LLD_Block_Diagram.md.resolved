## 10. Role-Based Access Control

```mermaid
graph LR
    subgraph Roles["User Roles"]
        INVESTOR["investor\n(client)"]
        ADVISOR["advisor"]
        ADMIN["admin"]
    end

    subgraph InvestorAccess["Investor Endpoints"]
        IE1["PUT /investor/profile"]
        IE2["GET /investor/profile"]
        IE3["POST /investor/invest"]
        IE4["POST /investor/invest-all"]
        IE5["GET /investor/portfolio"]
        IE6["GET /investor/pending-orders"]
        IE7["GET /investor/history"]
        IE8["POST /recommendations/"]
    end

    subgraph AdvisorAccess["Advisor Endpoints"]
        AE1["GET /advisor/clients"]
        AE2["GET /advisor/clients/:id/profile"]
        AE3["GET /advisor/clients/:id/portfolio"]
        AE4["GET /advisor/clients/:id/recommendations"]
        AE5["GET /advisor/orders"]
        AE6["POST /advisor/orders/:id/approve"]
        AE7["POST /advisor/orders/:id/reject"]
    end

    subgraph AdminAccess["Admin Endpoints"]
        ADM1["GET /admin/stats"]
        ADM2["GET /admin/users"]
        ADM3["GET/POST/PUT/DELETE /admin/funds"]
        ADM4["POST /admin/ingest/nav"]
        ADM5["POST /admin/ingest/metrics"]
        ADM6["GET /admin/approved-orders"]
    end

    subgraph SharedAccess["Shared (Auth Required)"]
        SA1["GET /auth/me"]
        SA2["POST /auth/change-password"]
        SA3["POST /auth/logout"]
        SA4["POST /auth/refresh"]
        SA5["GET /funds/"]
        SA6["GET /funds/:code"]
    end

    INVESTOR --> IE1 & IE2 & IE3 & IE4 & IE5 & IE6 & IE7 & IE8
    ADVISOR --> AE1 & AE2 & AE3 & AE4 & AE5 & AE6 & AE7
    ADMIN --> ADM1 & ADM2 & ADM3 & ADM4 & ADM5 & ADM6
    INVESTOR & ADVISOR & ADMIN --> SA1 & SA2 & SA3 & SA4 & SA5 & SA6
```

