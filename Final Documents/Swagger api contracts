                email:
                  type: string
                  example: "newclient@example.com"
                password:
                  type: string
                  example: "securePass123"
                name:
                  type: string
                  example: "New Client"
                role:
                  type: string
                  enum: [client, advisor]
                  example: "client"
                phone:
                  type: string
                  example: "+919876543210"
                arn:
                  type: string
